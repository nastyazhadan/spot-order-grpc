ORDER_ADDRESS=:50051
SPOT_INSTRUMENT_LISTEN_ADDRESS=:50052
SPOT_INSTRUMENT_DIAL_ADDRESS=localhost:50052

ORDER_CREATE_TIMEOUT=5s
ORDER_CHECK_TIMEOUT=15s

# postgres
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password
POSTGRES_PORT=5433

ORDER_DB=order_db
SPOT_DB=spot_db

ORDER_DB_URI=postgres://your_user:your_password@localhost:5433/order_db?sslmode=disable
SPOT_DB_URI=postgres://your_user:your_password@localhost:5433/spot_db?sslmode=disable

PG_POOL_MAX_CONNS=10
PG_POOL_MIN_CONNS=2
PG_POOL_MAX_CONN_LIFETIME=30m
PG_POOL_MAX_CONN_IDLE_TIME=5m

# logger
LOG_LEVEL=info
LOG_FORMAT=console

# circuit breaker
CB_MAX_REQUESTS=3
CB_INTERVAL=10s
CB_TIMEOUT=5s
CB_MAX_FAILURES=5

# graceful shutdown
GS_TIMEOUT=15s

# redis
REDIS_HOST=localhost
REDIS_PORT=6379
EXTERNAL_REDIS_PORT=6379
REDIS_CONNECTION_TIMEOUT=10s
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE=2
REDIS_MAX_IDLE=10
REDIS_MAX_ACTIVE_CONNS=15
REDIS_IDLE_TIMEOUT=1m
REDIS_CONN_MAX_LIFETIME=30m
SPOT_REDIS_CACHE_TTL=24h

# rate limiter
RATE_LIMIT_CREATE_ORDER=5
RATE_LIMIT_GET_ORDER_STATUS=50
RATE_LIMIT_WINDOW=1h
