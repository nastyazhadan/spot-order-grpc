JWT_SECRET=your_secret_key

# postgres
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password
POSTGRES_PORT=5433

ORDER_DB=order_db
SPOT_DB=spot_db

ORDER_DB_URI=postgres://your_user:your_password@localhost:5432/order_db?sslmode=disable
SPOT_DB_URI=postgres://your_user:your_password@localhost:5432/spot_db?sslmode=disable

# redis
EXTERNAL_REDIS_PORT=6379

# metrics
OTEL_GRPC_PORT=4317
OTEL_HEALTHCHECK_PORT=13133

PROMETHEUS_METRICS_PORT=8888
PROMETHEUS_PORT=9090

ORDER_METRICS_PORT=9091
SPOT_METRICS_PORT=9092

GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=your_user
GRAFANA_ADMIN_PASSWORD=your_password

TEMPO_HTTP_PORT=3200

# kafka
KAFKA_EXTERNAL_PORT=9092
KAFKA_INTERNAL_PORT=29092
KAFKA_CONTROLLER_PORT=29093
KAFKA_UI_PORT=8090
