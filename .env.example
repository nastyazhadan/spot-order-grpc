# postgres
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password
POSTGRES_PORT=5433

ORDER_DB=order_db
SPOT_DB=spot_db

ORDER_DB_URI=postgres://your_user:your_password@localhost:5433/order_db?sslmode=disable
SPOT_DB_URI=postgres://your_user:your_password@localhost:5433/spot_db?sslmode=disable

# redis
EXTERNAL_REDIS_PORT=6379

# open telemetry collector
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
OTEL_METRICS_PORT=8888
OTEL_ZPAGES_PORT=8889

# jaeger
JAEGER_UI_PORT=16686
